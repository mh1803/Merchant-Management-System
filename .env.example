NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/merchant_management
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
WEBHOOK_SIGNING_SECRET=replace_with_webhook_secret
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
OPERATORS_FILE=data/operators.json
