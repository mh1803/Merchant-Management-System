{
  "name": "merchant-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "Backend CRM engine for merchant onboarding and KYB management.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start:dev": "npm run db:migrate && npm run dev",
    "start": "node dist/server.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "ops": "bash scripts/ops.sh",
    "ops:health": "bash scripts/ops.sh health",
    "ops:login": "bash scripts/ops.sh login",
    "ops:refresh": "bash scripts/ops.sh refresh",
    "ops:token": "bash scripts/ops.sh token",
    "ops:auth-header": "bash scripts/ops.sh auth-header",
    "ops:set-operator": "bash scripts/ops.sh set-operator",
    "operator:set": "tsx scripts/set-operator.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/pg": "^8.15.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.10",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
