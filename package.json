{
  "name": "merchant-management-system",
  "version": "0.1.0",
  "private": true,
  "description": "Backend CRM engine for merchant onboarding and KYB management.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start:dev": "npm run db:migrate && npm run dev",
    "start": "node dist/server.js",
    "db:migrate": "tsx scripts/migrate.ts",
    "ops": "bash scripts/ops.sh",
    "ops:health": "bash scripts/ops.sh health",
    "ops:auth:login": "bash scripts/ops.sh auth:login",
    "ops:auth:refresh": "bash scripts/ops.sh auth:refresh",
    "ops:auth:token": "bash scripts/ops.sh auth:token",
    "ops:auth:header": "bash scripts/ops.sh auth:header",
    "ops:merchant:create": "bash scripts/ops.sh merchant:create",
    "ops:merchant:list": "bash scripts/ops.sh merchant:list",
    "ops:merchant:get": "bash scripts/ops.sh merchant:get",
    "ops:merchant:update": "bash scripts/ops.sh merchant:update",
    "ops:merchant:delete": "bash scripts/ops.sh merchant:delete",
    "ops:merchant:set-pricing-tier": "bash scripts/ops.sh merchant:set-pricing-tier",
    "ops:merchant:history": "bash scripts/ops.sh merchant:history",
    "ops:kyb:add-doc": "bash scripts/ops.sh kyb:add-doc",
    "ops:kyb:list-docs": "bash scripts/ops.sh kyb:list-docs",
    "ops:kyb:get-doc": "bash scripts/ops.sh kyb:get-doc",
    "ops:kyb:history": "bash scripts/ops.sh kyb:history",
    "ops:kyb:verify-doc": "bash scripts/ops.sh kyb:verify-doc",
    "ops:webhook:subscribe": "bash scripts/ops.sh webhook:subscribe",
    "ops:auth:set-operator": "bash scripts/ops.sh auth:set-operator",
    "operator:set": "tsx scripts/set-operator.ts",
    "test": "jest --runInBand",
    "test:http": "RUN_HTTP_TESTS=true jest --runInBand tests/*.http.test.ts",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
